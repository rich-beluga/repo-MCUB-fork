# Display bot logs.

import os
from pathlib import Path

DESCRIPTION = "Display bot logs (kernel.log, errors, etc.)."


def _colorize(line):
    line = line.rstrip("\n")
    if "ERROR" in line or "error" in line or "Error" in line:
        return f"\033[91m{line}\033[0m"
    elif "WARN" in line or "Warning" in line:
        return f"\033[93m{line}\033[0m"
    elif "INFO" in line or "info" in line:
        return f"\033[96m{line}\033[0m"
    elif "DEBUG" in line or "debug" in line:
        return f"\033[90m{line}\033[0m"
    return line


def _get_logs_dir(shell):
    kernel = getattr(shell, "kernel", None)
    
    if kernel:
        logs_dir = Path.cwd() / "logs"
        if logs_dir.exists():
            return logs_dir
    
    logs_dir = Path("logs")
    if logs_dir.exists():
        return logs_dir
    
    return None


async def run(shell, args):
    logs_dir = _get_logs_dir(shell)
    
    if not logs_dir or not logs_dir.exists():
        shell.output("\033[91mLogs directory not found\033[0m")
        return
    
    shell.output(f"\n\033[96m\033[1mBot Logs\033[0m\n")
    shell.output(f"  \033[90mDirectory: {logs_dir}\033[0m\n")
    
    if not args:
        await _show_kernel_log(shell, logs_dir, 50)
        return
    
    cmd = args[0]
    
    if cmd == "list":
        await _list_logs(shell, logs_dir)
    elif cmd == "errors":
        count = int(args[1]) if len(args) > 1 and args[1].isdigit() else 20
        await _show_errors(shell, logs_dir, count)
    elif cmd.isdigit():
        await _show_kernel_log(shell, logs_dir, int(cmd))
    else:
        await _show_file(shell, logs_dir, cmd, 50)


async def _list_logs(shell, logs_dir):
    files = sorted(logs_dir.glob("*"), key=lambda x: x.stat().st_mtime, reverse=True)
    
    shell.output(f"  \033[93mAvailable logs:\033[0m\n")
    for f in files[:15]:
        size = f.stat().st_size
        if size > 1024 * 1024:
            size_str = f"{size / (1024*1024):.1f}M"
        elif size > 1024:
            size_str = f"{size / 1024:.1f}K"
        else:
            size_str = f"{size}B"
        shell.output(f"  \033[96m{f.name:<30}\033[0m {size_str}")


async def _show_kernel_log(shell, logs_dir, count):
    kernel_log = logs_dir / "kernel.log"
    if not kernel_log.exists():
        shell.output("\033[91mkernel.log not found\033[0m")
        return
    
    shell.output(f"  \033[93mLast {count} lines from kernel.log:\033[0m\n")
    
    try:
        with open(kernel_log, "r", encoding="utf-8", errors="ignore") as f:
            lines = f.readlines()
            for line in lines[-count:]:
                shell.output(f"  {_colorize(line)}")
    except Exception as e:
        shell.output(f"\033[91mError reading file: {e}\033[0m")


async def _show_errors(shell, logs_dir, count):
    error_files = sorted(logs_dir.glob("errors_*.log"), key=lambda x: x.stat().st_mtime, reverse=True)
    
    if not error_files:
        shell.output("\033[90mNo error logs found\033[0m")
        return
    
    shell.output(f"  \033[93mLast {count} errors:\033[0m\n")
    
    all_errors = []
    for f in error_files:
        try:
            with open(f, "r", encoding="utf-8", errors="ignore") as fp:
                lines = fp.readlines()
                all_errors.extend([(f.name, line) for line in lines[-50:]])
        except:
            continue
    
    all_errors = all_errors[-count:]
    for filename, line in all_errors:
        shell.output(f"  \033[90m[{filename}]\033[0m {_colorize(line)}")


async def _show_file(shell, logs_dir, filename, count):
    log_file = logs_dir / filename
    if not log_file.exists():
        shell.output(f"\033[91mFile {filename} not found\033[0m")
        return
    
    shell.output(f"  \033[93m{filename} (last {count} lines):\033[0m\n")
    
    try:
        with open(log_file, "r", encoding="utf-8", errors="ignore") as f:
            lines = f.readlines()
            for line in lines[-count:]:
                shell.output(f"  {_colorize(line)}")
    except Exception as e:
        shell.output(f"\033[91mError reading file: {e}\033[0m")
